    ->     User_ID INT,
    ->     Gender VARCHAR(10),
    ->     Age INT,
    ->     EstimatedSalary INT,
    ->     Purchased INT
    -> );
 SHOW TABLES;
SELECT COUNT(*) FROM social_network_ads;

